   <FUNCTIONS>
    <item>
     <FUNCNAME>ZAGE_FM_HELLO</FUNCNAME>
     <SHORT_TEXT>Hello world function module</SHORT_TEXT>
     <IMPORT>
      <RSIMP>
       <PARAMETER>IV_NAME</PARAMETER>
       <TYP>STRING</TYP>
      </RSIMP>
     </IMPORT>
     <EXPORT>
      <RSEXP>
       <PARAMETER>EV_GREETING</PARAMETER>
       <TYP>STRING</TYP>
      </RSEXP>
     </EXPORT>
     <CHANGING>
      <RSCHA>
       <PARAMETER>CV_COUNTER</PARAMETER>
       <TYP>I</TYP>
      </RSCHA>
     </CHANGING>
    </item>
    <item>
     <FUNCNAME>ZAGE_FM_CALC</FUNCNAME>
     <SHORT_TEXT>Calculator function module</SHORT_TEXT>
     <IMPORT>
      <RSIMP>
       <PARAMETER>IV_A</PARAMETER>
       <TYP>I</TYP>
      </RSIMP>
      <RSIMP>
       <PARAMETER>IV_B</PARAMETER>
       <TYP>I</TYP>
      </RSIMP>
      <RSIMP>
       <PARAMETER>IV_OPERATION</PARAMETER>
       <TYP>STRING</TYP>
       <DEFAULT>&apos;ADD&apos;</DEFAULT>
       <OPTIONAL>X</OPTIONAL>
      </RSIMP>
     </IMPORT>
     <EXPORT>
      <RSEXP>
       <PARAMETER>EV_RESULT</PARAMETER>
       <TYP>I</TYP>
      </RSEXP>
     </EXPORT>
    </item>
   </FUNCTIONS>
